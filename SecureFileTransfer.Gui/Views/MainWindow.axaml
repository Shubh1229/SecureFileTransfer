<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SecureFileTransfer.Gui.ViewModels"
        x:Class="SecureFileTransfer.Gui.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="900"
        Height="600"
        Title="Secure File Transfer">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <DockPanel>

        <!-- Persistent footer on every page -->
        <Border DockPanel.Dock="Bottom"
                Padding="12,8"
                BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Spacing="8">
                <TextBlock Text="Made by Arihant Singh"
                           VerticalAlignment="Center"
                           Opacity="0.7"
                           FontSize="12"/>
                <TextBlock Text="·"
                           VerticalAlignment="Center"
                           Opacity="0.4"
                           FontSize="12"/>
                <HyperlinkButton Content="GitHub"
                                 NavigateUri="https://github.com/Shubh1229/SecureFileTransfer"
                                 VerticalAlignment="Center"
                                 FontSize="12"/>
            </StackPanel>
        </Border>

        <!-- Active page resolved by ViewLocator -->
        <ContentControl Content="{Binding CurrentPage}"/>

    </DockPanel>

</Window>

