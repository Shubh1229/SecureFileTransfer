<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SecureFileTransfer.Gui.ViewModels"
             x:Class="SecureFileTransfer.Gui.Views.HomeView"
             x:DataType="vm:HomeViewModel">

    <Grid RowDefinitions="*,Auto,*">
        <StackPanel Grid.Row="1"
                    HorizontalAlignment="Center"
                    Spacing="24"
                    MaxWidth="320">

            <StackPanel Spacing="6" HorizontalAlignment="Center">
                <TextBlock Text="Secure File Transfer"
                           FontSize="32"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Encrypted peer-to-peer file transfer"
                           FontSize="14"
                           Opacity="0.6"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <Button Content="Host / Receive Files"
                    Command="{Binding NavigateToHostCommand}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Height="48"/>

            <Button Content="Send Files"
                    Command="{Binding NavigateToClientCommand}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Height="48"/>

            <Button Content="Settings"
                    Command="{Binding NavigateToSettingsCommand}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Height="48"/>

        </StackPanel>
    </Grid>

</UserControl>
